#!/usr/bin/env sh
set -eu

usage() {
  cat <<'USAGE'
Usage: bin/worktree-setup [WORKTREE_PATH] [WORKTREE_NAME]

Sets up a linked Git worktree after creation: runs npm ci in vue and hocuspocus,
writes a worktree-specific TEST_DATABASE_URL, and prepares the Rails test DB.

When WORKTREE_NAME is omitted, it is inferred from WORKTREE_PATH. For paths like
.../worktrees/loomio/ready-bolt/loomio, the inferred name is ready-bolt.
USAGE
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

worktree_path="${1:-$(git rev-parse --show-toplevel)}"
repo_name="$(basename "$worktree_path")"

if [ "${2:-}" != "" ]; then
  worktree_name="$2"
elif [ "$repo_name" = "loomio" ]; then
  worktree_name="$(basename "$(dirname "$worktree_path")")"
else
  worktree_name="$repo_name"
fi

db_suffix="$(printf '%s' "$worktree_name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/_/g; s/^_*//; s/_*$//; s/__*/_/g')"

if [ -z "$db_suffix" ]; then
  echo "Worktree name must contain at least one letter or number" >&2
  exit 1
fi

database_name="loomio_test_$db_suffix"
test_database_url="postgresql:///$database_name"

cat > "$worktree_path/config/database.yml" <<'YAML'
development:
  adapter: postgresql
  database: loomio_development

test:
  adapter: postgresql
  url: <%= ENV.fetch("TEST_DATABASE_URL", "postgresql:///loomio_test") %>
YAML

printf 'TEST_DATABASE_URL=%s\n' "$test_database_url" > "$worktree_path/.env.test.local"

(
  cd "$worktree_path/vue"
  npm ci
)

(
  cd "$worktree_path/hocuspocus"
  npm ci
)

(
  cd "$worktree_path"
  RAILS_ENV=test TEST_DATABASE_URL="$test_database_url" bin/rails db:prepare
)

cat <<SUMMARY
Set up worktree: $worktree_path
Worktree name: $worktree_name
Test database: $database_name
TEST_DATABASE_URL written to: $worktree_path/.env.test.local
SUMMARY
